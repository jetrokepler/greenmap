
# .env.example — template de variáveis de ambiente

# COMO USAR:
#   1. Copie este arquivo: cp .env.example .env
#   2. Edite o .env com suas credenciais reais
#   3. NUNCA suba o .env para o Git (já está no .gitignore)

# Por que usar .env?
#   Evita deixar senha hardcoded no código.
#   Cada desenvolvedor tem seu próprio .env local.

# Quando usar Docker Compose:
#   As variáveis já estão definidas no docker-compose.yml,
#   então o .env só é necessário para rodar SEM Docker.

DB_HOST=localhost
DB_PORT=5432
DB_NAME=greenmap
DB_USER=greenmap_user
DB_PASSWORD=greenmap_pass
